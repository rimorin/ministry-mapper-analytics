# =============================================================================
# Ministry Mapper Analytics - Environment Configuration
# =============================================================================
# Copy this file to .env and update the values before deploying.
#
#   cp .env.example .env
#
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — Secrets (unique per environment)
# -----------------------------------------------------------------------------

# Strong random secret for Umami session encryption (min 32 chars recommended)
# Generate with: openssl rand -hex 32
APP_SECRET=

# PostgreSQL password (use a strong random value)
# Generate with: openssl rand -hex 16
POSTGRES_PASSWORD=

# -----------------------------------------------------------------------------
# Optional — Umami Configuration
# -----------------------------------------------------------------------------

# Comma-separated list of IPs to exclude from tracking
# Example: IGNORE_IP=192.168.1.1,10.0.0.0/8
IGNORE_IP=

# -----------------------------------------------------------------------------
# Resource Limits (defaults are staging/dev — see README for other presets)
# -----------------------------------------------------------------------------

# Umami
UMAMI_CPU_LIMIT=0.25
UMAMI_MEMORY_LIMIT=256M
UMAMI_CPU_RESERVATION=0.1
UMAMI_MEMORY_RESERVATION=128M

# PostgreSQL
DB_CPU_LIMIT=0.25
DB_MEMORY_LIMIT=256M
DB_CPU_RESERVATION=0.1
DB_MEMORY_RESERVATION=64M

# -----------------------------------------------------------------------------
# PostgreSQL Performance Tuning
# -----------------------------------------------------------------------------

POSTGRES_SHM_SIZE=128m
POSTGRES_SHARED_BUFFERS=32MB
POSTGRES_WORK_MEM=1MB
POSTGRES_MAINTENANCE_WORK_MEM=16MB
POSTGRES_EFFECTIVE_CACHE_SIZE=128MB
POSTGRES_MAX_CONNECTIONS=30
